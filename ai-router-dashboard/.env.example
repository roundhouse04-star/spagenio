PORT=3000
N8N_WEBHOOK_URL=
OPENCLAW_WEBHOOK_URL=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_ENGINE=hybrid
DEFAULT_MODEL=gemini
DEFAULT_PRIORITY_MODE=balanced
REQUEST_TIMEOUT_MS=20000
PERF_PROFILE=turbo-local

# ── 보안 시크릿 (필수, 기본값 fallback 제거됨) ───────────
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ JWT_SECRET 변경 시: 모든 사용자 재로그인 필요
# ⚠️ ENCRYPT_KEY 변경 시: 기존 암호화된 Alpaca 키 복호화 불가 → 계좌 재등록 필요
JWT_SECRET=
ADMIN_JWT_SECRET=
ENCRYPT_KEY=

# ── Alpaca (주식 매매) ────────────────────────────────────
# ⚠️ 키는 절대 코드에 하드코딩하지 말 것. .env 만 사용.
# ⚠️ 이전 키가 git history에 노출되었다면 즉시 폐기·재발급:
#    https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# ── Python 서비스 보호 ───────────────────────────────────
# Node 대시보드 → Python(stock_server.py / quant_engine.py) 호출 시
# X-Internal-Token 헤더로 검증. mutating 엔드포인트는 이 토큰 없으면 거부.
# 생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_TOKEN=
# 1회 주문 최대 수량 한도 (사고 방지)
MAX_ORDER_QTY=10
# Python 서비스 바인딩 호스트 (기본 127.0.0.1, 외부 노출 금지)
PYTHON_HOST=127.0.0.1
# CORS 허용 origin (콤마 분리)
CORS_ORIGIN=http://localhost:3000
