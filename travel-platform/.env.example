# ─── travel-platform 환경변수 템플릿 ─────────────────────────
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값으로 채우기
#   cp .env.example .env

# Gmail SMTP (이메일 인증코드 발송용)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# JWT 서명 키 (32바이트 hex 권장: openssl rand -hex 32)
SECRET_KEY=

# 관리자 로그인
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 토큰 만료 시간 (시간 단위)
TOKEN_EXPIRE_HOURS=24

# 업로드 파일 URL 베이스 (로컬 개발 / 운영에 따라 변경)
BASE_URL=http://localhost:4173
